VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-or-publishable-key

# Market data is fetched via Supabase Edge Function `market-proxy` (not directly from the browser).
# Set these secrets on the Supabase project (Dashboard → Edge Functions → Secrets):
#   MARKET_API_BASE_URL=https://{api-id}.execute-api.ca-west-1.amazonaws.com/v1
#   MARKET_GATEWAY_API_KEY=<SERVING_API_KEY from the dev-serving-api Lambda>
